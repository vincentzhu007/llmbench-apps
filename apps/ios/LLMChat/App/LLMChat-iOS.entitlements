<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Raise the per-app memory ceiling so the 4B model (several GB of
	     weights + KV cache) can load on 8GB iPhones. -->
	<key>com.apple.developer.kernel.increased-memory-limit</key>
	<true/>
	<!-- Grow the virtual address space so MPSGraph can allocate large
	     contiguous buffers (avoids std::bad_alloc at load). -->
	<key>com.apple.developer.kernel.extended-virtual-addressing</key>
	<true/>
</dict>
</plist>
